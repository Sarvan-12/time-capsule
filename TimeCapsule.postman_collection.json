{
  "info": {
    "name": "Digital Time Capsule API",
    "description": "API collection for Digital Time Capsule MERN app",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "http://localhost:5000/api/auth/register", "host": ["http://localhost:5000"], "path": ["api", "auth", "register"] }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "http://localhost:5000/api/auth/login", "host": ["http://localhost:5000"], "path": ["api", "auth", "login"] }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "http://localhost:5000/api/auth/me", "host": ["http://localhost:5000"], "path": ["api", "auth", "me"] }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "http://localhost:5000/api/auth/refresh", "host": ["http://localhost:5000"], "path": ["api", "auth", "refresh"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "http://localhost:5000/api/auth/logout", "host": ["http://localhost:5000"], "path": ["api", "auth", "logout"] }
          }
        }
      ]
    },
    {
      "name": "Capsules",
      "item": [
        {
          "name": "Create Capsule",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My First Capsule\",\n  \"content\": \"<p>Hello Future Me!</p>\",\n  \"unlockDate\": \"2026-12-31T00:00:00Z\",\n  \"deliveryMode\": \"both\",\n  \"privacy\": \"private\",\n  \"recipients\": [\n    { \"email\": \"test@example.com\" }\n  ]\n}"
            },
            "url": { "raw": "http://localhost:5000/api/capsules", "host": ["http://localhost:5000"], "path": ["api", "capsules"] }
          }
        },
        {
          "name": "Get My Capsules",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "http://localhost:5000/api/capsules", "host": ["http://localhost:5000"], "path": ["api", "capsules"] }
          }
        },
        {
          "name": "Get Single Capsule",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "http://localhost:5000/api/capsules/{{capsule_id}}", "host": ["http://localhost:5000"], "path": ["api", "capsules", "{{capsule_id}}"] }
          }
        },
        {
          "name": "Update Capsule",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Capsule Title\"\n}"
            },
            "url": { "raw": "http://localhost:5000/api/capsules/{{capsule_id}}", "host": ["http://localhost:5000"], "path": ["api", "capsules", "{{capsule_id}}"] }
          }
        },
        {
          "name": "Seal Capsule",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "http://localhost:5000/api/capsules/{{capsule_id}}/seal", "host": ["http://localhost:5000"], "path": ["api", "capsules", "{{capsule_id}}", "seal"] }
          }
        },
        {
          "name": "Delete Capsule",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "http://localhost:5000/api/capsules/{{capsule_id}}", "host": ["http://localhost:5000"], "path": ["api", "capsules", "{{capsule_id}}"] }
          }
        },
        {
          "name": "Get Inbox",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "http://localhost:5000/api/capsules/inbox", "host": ["http://localhost:5000"], "path": ["api", "capsules", "inbox"] }
          }
        },
        {
          "name": "Get Public Capsules",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "http://localhost:5000/api/capsules/public", "host": ["http://localhost:5000"], "path": ["api", "capsules", "public"] }
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "Get Notifications",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "http://localhost:5000/api/notifications", "host": ["http://localhost:5000"], "path": ["api", "notifications"] }
          }
        },
        {
          "name": "Mark as Read",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "http://localhost:5000/api/notifications/{{notification_id}}/read", "host": ["http://localhost:5000"], "path": ["api", "notifications", "{{notification_id}}", "read"] }
          }
        }
      ]
    }
  ]
}
